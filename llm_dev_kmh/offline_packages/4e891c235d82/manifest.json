      "id": "osm_extract",
      "name": "OpenStreetMap PBF Extract",
      "provider": "Geofabrik / OpenStreetMap contributors",
      "category": "vector",
      "purpose": "Geofabrik regional OSM PBF downloaded to the Jetson and clipped to the selected AOI for roads, trails, waterways, buildings, POIs, and barriers.",
      "stream_status": "not-streamed",
      "download_status": "download-required",
      "stream_layer": null,
      "analysis_role": "Primary local vector dataset for database-backed graph, POI, hydro, access, and Valhalla tile-build queries.",
