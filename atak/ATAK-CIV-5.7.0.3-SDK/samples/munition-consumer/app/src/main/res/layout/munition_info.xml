<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="3dp"
    android:paddingBottom="3dp"
    android:orientation="vertical" >

    <TextView
        android:id="@+id/name"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:id="@+id/description"
        android:layout_width="match_parent"
        android:textSize="12sp"
        android:layout_height="wrap_content"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:weightSum="2"
        android:orientation="horizontal" >
        <TextView
            android:id="@+id/group"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:textSize="11sp"
            android:layout_height="wrap_content"/>
        <TextView
            android:id="@+id/category"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:textSize="11sp"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:weightSum="5"
        android:orientation="horizontal" >
        <TextView
            android:layout_width="0dp"
            android:text="@string/standing"
            android:textSize="11sp"
            android:textColor="@color/heading_yellow"
            android:layout_weight="1"
            android:layout_height="wrap_content"/>
        <TextView
            android:layout_width="0dp"
            android:text="@string/prone"
            android:textSize="11sp"
            android:textColor="@color/heading_yellow"
            android:layout_weight="1"
            android:layout_height="wrap_content"/>
        <TextView
            android:layout_width="0dp"
            android:text="@string/prone_protected"
            android:textSize="11sp"
            android:textColor="@color/heading_yellow"
            android:layout_weight="1.5"
            android:layout_height="wrap_content"/>

        <TextView
            android:layout_width="0dp"
            android:text="@string/ricochet_fan"
            android:textSize="11sp"
            android:textColor="@color/heading_yellow"
            android:layout_weight="1.5"
            android:layout_height="wrap_content"/>

    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:weightSum="5"
        android:orientation="horizontal" >
        <TextView
            android:id="@+id/standing"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"/>
        <TextView
            android:id="@+id/prone"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"/>
        <TextView
            android:id="@+id/proneprotected"
            android:layout_width="0dp"
            android:layout_weight="1.5"
            android:layout_height="wrap_content"/>
        <TextView
            android:id="@+id/ricochetfan"
            android:layout_width="0dp"
            android:layout_weight="1.5"
            android:layout_height="wrap_content" />
    </LinearLayout>

</LinearLayout>

