# Local-only configuration. Copy to .env and fill values on the demo machine.

# Optional for Cesium terrain/building workflows in RFSim or local preview tools.
# Never commit a real Cesium ion token.
CESIUM_ION_TOKEN=

# TERA agent endpoint used by the ATAK plugin pane during local testing.
TERA_PLAN_ENDPOINT=http://127.0.0.1:8000/plan
